<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ОСНОВНАЯ ТЕМА ПРИЛОЖЕНИЯ — ОБЯЗАТЕЛЬНО ДОЛЖНА БЫТЬ -->
    <style name="Theme.App" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Цвета берутся из values/colors.xml или values-night/colors.xml -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Фон -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Статус-бар -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Для Material Components -->
        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>

        <!-- Для Android 10+ (если нужно тёмное оформление системных элементов) -->
        <item name="android:windowLightStatusBar">false</item> <!-- текст в статус-баре — светлый -->
        <item name="android:windowLightNavigationBar">false</item> <!-- кнопки навигации — светлые -->

    </style>

    <!-- Splash Theme -->
    <style name="SplashTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_anim_vector</item>
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimationDuration">1500</item>
        <item name="postSplashScreenTheme">@style/Theme.App</item>
    </style>

</resources>